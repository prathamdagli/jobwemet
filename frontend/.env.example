# ---------------------------------------------------------------------------
# JobWeMet frontend (.env.example)
# Copy to `.env` and fill in. DO NOT commit `.env`.
# Values come from your Firebase Web App (Project settings → Your apps).
# ---------------------------------------------------------------------------

# Firebase web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=jobwemet-bedd8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=jobwemet-bedd8
VITE_FIREBASE_STORAGE_BUCKET=jobwemet-bedd8.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend base URL (no trailing slash).
# Local dev:  http://127.0.0.1:8000
# Production: https://<your-backend>.onrender.com
VITE_API_BASE_URL=http://127.0.0.1:8000
