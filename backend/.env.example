# ---------------------------------------------------------------------------
# JobWeMet backend (.env.example)
# Copy to `.env` and fill in. DO NOT commit `.env`.
# ---------------------------------------------------------------------------

# --- Firebase Admin SDK ---------------------------------------------------
# Path to a service-account JSON file. If blank, the backend falls back to
# backend/service-account.json (git-ignored). This file is REQUIRED — the
# backend fails fast at startup if no credential is found.
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase project id (mirrors the frontend's VITE_FIREBASE_PROJECT_ID).
FIREBASE_PROJECT_ID=jobwemet-bedd8

# Cloud Storage bucket, e.g. "jobwemet-bedd8.firebasestorage.app".
FIREBASE_STORAGE_BUCKET=jobwemet-bedd8.firebasestorage.app

# --- CORS -----------------------------------------------------------------
# Comma-separated allowed origins for the frontend. "*" allows all.
ALLOWED_ORIGINS=*

# --- Authentication -------------------------------------------------------
# When true, every request must carry a valid Firebase ID token.
# When false (local dev), requests fall back to DEMO_UID.
REQUIRE_AUTH=false
DEMO_UID=demo-user

# --- AI provider ----------------------------------------------------------
# Active provider: "stub" | "groq".
# "stub" returns deterministic placeholder output when no key is configured.
# Use "groq" with a real GROQ_API_KEY for live generation.
AI_PROVIDER=groq

# Groq credentials/endpoint. The key is required whenever
# AI_PROVIDER=groq. Never commit a real key — put it only in `.env`.
GROQ_API_KEY=

# Default model. Configurable from .env — never hard-coded in code.
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional fallback models
GROQ_FALLBACK_MODEL=qwen/qwen3-32b
GROQ_SECONDARY_MODEL=llama-3.3-70b-versatile
