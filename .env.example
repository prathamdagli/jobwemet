# ─────────────────────────────────────────────────────────────────────────────
# JobWeMet — local environment template
#
# Copy this file to `.env` (which is gitignored) and fill in your values.
# NEVER commit a real `.env`. Keep secrets out of the repository.
# The frontend already provides VITE_FIREBASE_* via its own `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase web app config (mirrors the frontend's VITE_FIREBASE_* values)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=jobwemet-bedd8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=jobwemet-bedd8
VITE_FIREBASE_STORAGE_BUCKET=jobwemet-bedd8.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Python (FastAPI) backend config ────────────────────────────────────────
# The backend is a FastAPI app talking directly to Firebase. No Cloud Functions.

# Firebase Admin SDK credentials (service-account JSON), or leave blank to use
# Application Default Credentials / the Firestore emulator.
GOOGLE_APPLICATION_CREDENTIALS=

# Project + storage bucket (mirror the VITE_FIREBASE_* values above).
FIREBASE_PROJECT_ID=jobwemet-bedd8
FIREBASE_STORAGE_BUCKET=jobwemet-bedd8.firebasestorage.app

# CORS — comma-separated allowed origins for the frontend. "*" allows all.
ALLOWED_ORIGINS=*

# Authentication: when true, every request needs a Firebase ID token.
# When false (local dev), requests fall back to DEMO_UID.
REQUIRE_AUTH=false
DEMO_UID=demo-user

# AI provider: "stub" | "openrouter" (another provider later can be added
# without touching the rest of the app — everything goes through ai.py).
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
