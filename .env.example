# ─────────────────────────────────────────────────────────────────────────────
# JobWeMet — local environment template
#
# Copy this file to `.env` (which is gitignored) and fill in your values.
# NEVER commit a real `.env`. Keep secrets out of the repository.
# The frontend already provides VITE_FIREBASE_* via its own `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase web app config (mirrors the frontend's VITE_FIREBASE_* values)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=jobwemet-bedd8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=jobwemet-bedd8
VITE_FIREBASE_STORAGE_BUCKET=jobwemet-bedd8.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloud Functions runtime config (read via process.env from functions)
# Active AI provider: "stub" | "gemini" | "openai"
# AI logic is implemented in a later phase — this is prepared, not used yet.
AI_PROVIDER=stub

# Provider API keys — only required once AI features are implemented
GEMINI_API_KEY=
OPENAI_API_KEY=
