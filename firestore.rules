rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Per-user data: the profile doc and every subcollection beneath it are
    // readable and writable only by the owning authenticated user.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Global, admin-managed course catalog. Users may read it; writes go
    // through the Admin SDK / console, never the client.
    match /courses/{courseId} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
