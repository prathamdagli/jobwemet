rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Per-user data: the profile doc and every subcollection beneath it are
    // readable and writable only by the owning authenticated user.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Global, admin-managed course catalog. Users may read it; writes go
    // through the Admin SDK / console, never the client.
    match /courses/{courseId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Resume metadata: a top-level collection keyed by userId. A user may only
    // touch their own resumes. Records are created by the Admin SDK (Storage
    // onFinalize trigger) which bypasses rules; these rules gate client reads
    // and any client-side writes.
    match /resumes/{resumeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if signedIn() && (
        request.method == 'create'
          ? request.resource.data.userId == request.auth.uid
          : request.method == 'delete'
            ? resource.data.userId == request.auth.uid
            : request.resource.data.userId == request.auth.uid
      );
    }

    // Resume processing pipeline: a top-level collection keyed by userId, one
    // doc per resume. Same owner-only access as resumes; records are written
    // by the Admin SDK processing pipeline.
    match /resumeProcessing/{resumeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if signedIn() && (
        request.method == 'create'
          ? request.resource.data.userId == request.auth.uid
          : request.method == 'delete'
            ? resource.data.userId == request.auth.uid
            : request.resource.data.userId == request.auth.uid
      );
    }

    // AI analysis outputs: written exclusively by the Admin SDK analysis
    // pipeline (which bypasses these rules). Clients may read only their own
    // results; all client writes are denied.
    match /skillAnalysis/{resumeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /careerMatches/{resumeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /skillGap/{resumeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Learning pipeline outputs: written exclusively by the Admin SDK learning
    // pipeline (which bypasses these rules). Clients may read only their own
    // results; all client writes are denied.
    match /roadmaps/{resumeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /courseRecommendations/{resumeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /dashboardSummary/{resumeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
